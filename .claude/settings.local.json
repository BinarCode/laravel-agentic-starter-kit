{
    "permissions": {
        "allow": [
            "Bash(php artisan:*)",
            "Bash(composer show:*)",
            "Bash(composer run:*)",
            "Bash(curl -fsSL https://bun.sh/install)",
            "Bash(bash)",
            "Bash(export PATH=\"$HOME/.bun/bin:$PATH\")",
            "Bash(bun install:*)",
            "Bash(bun run:*)"
        ]
    },
    "enableAllProjectMcpServers": true,
    "enabledMcpjsonServers": ["laravel-boost"]
}
